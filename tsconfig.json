{
	"compilerOptions": {
		"baseUrl": ".",
		"inlineSourceMap": true,
		"inlineSources": true,
		"module": "ESNext",
		"target": "ES2021",
		"allowJs": true,
		"allowSyntheticDefaultImports": true,
		"noImplicitAny": true,
		"moduleResolution": "node",
		"importHelpers": false,
		"isolatedModules": true,
		"strictNullChecks": true,
		"strict": true,
		"noUncheckedIndexedAccess": true,
		"noImplicitReturns": true,
		"noFallthroughCasesInSwitch": true,
		"lib": [
			"ES2021",
			"DOM"
		]
	},
	"include": [
		"src/**/*.ts",
		"tests/**/*.ts"
	]
}
